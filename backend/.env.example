# Server Configuration
PORT=5000
NODE_ENV=production

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ECOM_DB?retryWrites=true&w=majority

# Security
JWT_SECRET=your_very_long_random_secret_key_at_least_32_chars

# CORS - Comma-separated list of allowed origins (use * for development only)
ALLOWED_ORIGINS=https://ecom-frontend-qh2t.onrender.com,https://ecom-fh0m.onrender.com

# Image Upload Limits
MAX_IMAGE_BYTES=1048576
MAX_IMAGES=5
